# Docker Compose: образ backend из CI (GitLab Container Registry).
# BACKEND_IMAGE=registry.gitlab.com/your-group/your-project/backend:latest

# Приложение
APP_NAME=crypto-scanner-backend
APP_ENV=development
# Язык по умолчанию: ru | en
APP_LANGUAGE=ru
APP_TIMEZONE=Asia/Almaty
APP_DEBUG=true

# HTTP
HTTP_ENABLE=true
HTTP_HOST=localhost
HTTP_PORT=4001

# Версионирование API
URL_VERSIONING_ENABLE=false
URL_VERSION=1

# Фоновые задачи (cron)
JOB_ENABLE=false

# Throttler (ограничение частоты запросов). В production включён всегда; в dev — только при true
THROTTLE_ENABLE=false

# CORS: whitelist origin через запятую (credentials=true, wildcard не используется)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4001

# MongoDB
DATABASE_URI=mongodb://appuser:iJXNoTVlWArivIa8h42IKidM@localhost:27018/app?authSource=admin
DATABASE_DEBUG=false
DATABASE_USERNAME=appuser
DATABASE_PASSWORD=iJXNoTVlWArivIa8h42IKidM
DATABASE_NAME=app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=KleJPahSscUUv80v15zcY7Wo
REDIS_DB=0

# URL приложения (для ссылок в письмах и локального хранилища)
SERVER_URL=http://localhost:4001

# Swagger
SWAGGER_URL=http://localhost:4001
DOC_ENABLE=true

# JWT
AUTH_JWT_SUBJECT=myapp
AUTH_JWT_ISSUER=https://example.com
AUTH_JWT_AUDIENCE=myapp-client
AUTH_JWT_ACCESS_TOKEN_EXPIRED=1d
AUTH_JWT_ACCESS_TOKEN_SECRET_KEY=uxddu9HKRsgpxT8t2zRnlGaA6hR5NBLWV6VIGzQal8vZiOS5
AUTH_JWT_REFRESH_TOKEN_EXPIRED=182d
AUTH_JWT_REFRESH_TOKEN_SECRET_KEY=HsruZuwm4OYWGRWOdwIXJgMkP8Zp11fONON77rI0SbSBtzke

# OAuth: Apple / Google
AUTH_SOCIAL_APPLE_CLIENT_ID=
AUTH_SOCIAL_APPLE_SIGN_IN_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_IOS_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_ANDROID_CLIENT_ID=
AUTH_SOCIAL_GOOGLE_CLIENT_SECRET=

# Токены для Basic Auth (админ vs пользователь)
TOKEN_SECRET_ADMIN=yFnXpVeW5e9j7p82X5A8aPfJKxApkpiC
TOKEN_SECRET_USER=EduFKAk1BdpFr93eqo7LlBANZmZCzR4s

# Хранилище файлов: local (диск)
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_PATH=uploads/media

# SMTP (восстановление пароля, уведомления)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=crypto-scanner
SMTP_FROM_ADDRESS=noreply@example.com

# Sentry (логирование ошибок)
SENTRY_DSN=

# E2E-тесты (опционально)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Telegram Mini App / Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=
TELEGRAM_ALERTS_ENABLED=true
# Long polling для локальной разработки (webhook = production)
TELEGRAM_USE_POLLING=false
# Секрет для POST /telegram/webhook (заголовок X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=

# Crypto Scanner
SCANNER_JOBS_ENABLED=true
SCANNER_ENABLED_EXCHANGES=binance,bybit,okx,gate,kucoin,kraken
SCANNER_DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT
SCANNER_MARKET_DATA_CACHE_TTL_SEC=60
SCANNER_SNAPSHOT_TTL_DAYS=7
SCANNER_DEFAULT_SPOT_FEE_RATE=0.001
SCANNER_DEFAULT_FUTURES_FEE_RATE=0.0005
SCANNER_DEFAULT_SLIPPAGE=0.0005
SCANNER_DEFAULT_POSITION_SIZE_USD=10000
# Фильтры арбитражного движка
SCANNER_ARBITRAGE_MIN_FUNDING_RATE=0.00001
SCANNER_ARBITRAGE_MIN_NET_YIELD=0
SCANNER_ARBITRAGE_MAX_SPREAD=2
SCANNER_ARBITRAGE_MIN_VOLUME_24H=100000
SCANNER_ARBITRAGE_SYMBOL_WHITELIST=
SCANNER_ARBITRAGE_SYMBOL_BLACKLIST=
SCANNER_ARBITRAGE_OPPORTUNITY_TTL_SEC=300
# Интервалы collectors (секунды)
SCANNER_INTERVAL_INSTRUMENTS_SEC=21600
SCANNER_INTERVAL_SPOT_SEC=45
SCANNER_INTERVAL_PERP_SEC=45
SCANNER_INTERVAL_FUNDING_SEC=180
SCANNER_INTERVAL_OI_SEC=180
SCANNER_INTERVAL_ARBITRAGE_SEC=45

# Exchange public API URLs (override для sandbox/testnet)
BINANCE_REST_URL=https://api.binance.com
BINANCE_FUTURES_URL=https://fapi.binance.com
BYBIT_REST_URL=https://api.bybit.com
OKX_REST_URL=https://www.okx.com
GATE_REST_URL=https://api.gateio.ws
KUCOIN_REST_URL=https://api.kucoin.com
KUCOIN_FUTURES_URL=https://api-futures.kucoin.com
KRAKEN_REST_URL=https://api.kraken.com
KRAKEN_FUTURES_URL=https://futures.kraken.com
EXCHANGE_REQUEST_TIMEOUT_MS=10000
EXCHANGE_RETRY_MAX_ATTEMPTS=3
EXCHANGE_RETRY_DELAY_MS=500
EXCHANGE_RATE_LIMIT_INTERVAL_MS=100

# Бекапы (scripts/backup.sh, restore.sh, docs/BACKUP.md)
MONGO_CONTAINER=app_db
REDIS_CONTAINER=app_redis
MONGO_USERNAME=appuser
MONGO_PASSWORD=iJXNoTVlWArivIa8h42IKidM
MONGO_DATABASE=app
BACKUP_KEEP_DAYS=7
