# Docker Compose: образ backend из CI (GitLab Container Registry).
# BACKEND_IMAGE=registry.gitlab.com/your-group/your-project/backend:latest

# Приложение
APP_NAME=MyApp-Backend
APP_ENV=development
# Язык по умолчанию: ru | en
APP_LANGUAGE=ru
APP_TIMEZONE=Asia/Almaty
APP_DEBUG=true

# HTTP
HTTP_ENABLE=true
HTTP_HOST=localhost
HTTP_PORT=4001

# Версионирование API
URL_VERSIONING_ENABLE=false
URL_VERSION=1

# Фоновые задачи (cron)
JOB_ENABLE=false

# Throttler (ограничение частоты запросов). В production включён всегда; в dev — только при true
THROTTLE_ENABLE=false

# CORS: whitelist origin через запятую (credentials=true, wildcard не используется)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4001

# MongoDB
DATABASE_URI=mongodb://appuser:iJXNoTVlWArivIa8h42IKidM@localhost:27018/app?authSource=admin
DATABASE_DEBUG=false
DATABASE_USERNAME=appuser
DATABASE_PASSWORD=iJXNoTVlWArivIa8h42IKidM
DATABASE_NAME=app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=KleJPahSscUUv80v15zcY7Wo
REDIS_DB=0

# URL приложения (для ссылок в письмах и локального хранилища)
SERVER_URL=http://localhost:4001

# Swagger
SWAGGER_URL=http://localhost:4001
DOC_ENABLE=true

# JWT
AUTH_JWT_SUBJECT=myapp
AUTH_JWT_ISSUER=https://example.com
AUTH_JWT_AUDIENCE=myapp-client
