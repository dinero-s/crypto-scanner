{
    "name": "nestjs-backend-template",
    "version": "0.0.1",
    "description": "Universal NestJS backend template with MongoDB, Redis, BullMQ",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "NODE_PATH=dist nest start",
        "start:dev": "NODE_PATH=dist NODE_OPTIONS='--max-old-space-size=4096' nest start --watch",
        "start:debug": "NODE_PATH=dist nest start --debug --watch",
        "start:prod": "NODE_PATH=dist node dist/src/main",
        "deploy": "bash deploy.sh",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "seed:dev": "ts-node -r tsconfig-paths/register scripts/seed-dev.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.826.0",
        "@aws-sdk/s3-request-presigner": "^3.826.0",
        "@faker-js/faker": "^8.4.1",
        "@nest-lab/throttler-storage-redis": "^1.2.0",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/axios": "^3.0.2",
        "@nestjs/bullmq": "^10.2.1",
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.2.3",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/mongoose": "^10.0.10",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/schedule": "^4.1.0",
        "@nestjs/swagger": "^7.4.0",
        "@nestjs/throttler": "^6.0.0",
        "@sentry/nestjs": "^8.22.0",
        "@sentry/profiling-node": "^8.22.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/crypto-js": "^4.2.2",
        "@types/lodash": "^4.17.7",
        "@types/multer": "^2.0.0",
        "axios": "^1.7.2",
        "bcryptjs": "^2.4.3",
        "bson": "6.10.3",
        "bullmq": "^5.19.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "crypto-js": "^4.2.0",
        "firebase-admin": "^12.7.0",
        "google-auth-library": "^10.6.1",
        "helmet": "^7.1.0",
        "json2csv": "^6.0.0-alpha.2",
        "jsonwebtoken": "^9.0.2",
        "moment-timezone": "^0.5.45",
        "mongoose": "^8.5.1",
        "mongoose-paginate-v2": "^1.8.3",
        "multer": "^2.1.1",
        "multer-gridfs-storage": "^5.0.2",
        "nest-winston": "^1.9.7",
        "nestjs-i18n": "^10.4.5",
        "nodemailer": "^6.9.14",
        "reflect-metadata": "^0.2.0",
        "response-time": "^2.3.2",
        "rxjs": "^7.8.1",
        "uuid": "^10.0.0",
        "verify-apple-id-token": "^3.1.2",
        "winston": "^3.13.1",
        "xlsx": "^0.18.5"
    },
    "resolutions": {
        "wrap-ansi": "^7.0.0",
        "string-width": "5.1.2"
    },
    "devDependencies": {
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.1",
        "@types/supertest": "^6.0.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.5.0",
        "prettier": "^3.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3",
        "typescript-eslint": "^8.56.1"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "moduleNameMapper": {
            "^src/(.*)$": "<rootDir>/$1"
        },
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
